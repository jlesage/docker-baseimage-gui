#!/bin/sh

set -e # Exit immediately if a command exits with a non-zero status.
set -u # Treat unset variables as an error.

#
# DISPLAY selection (host networking note):
#
# With --network=host, X11 abstract sockets from the host are visible
# inside the container. For DISPLAY=:N, libX11 may prefer the abstract
# socket @/tmp/.X11-unix/XN before the filesystem socket.
#
# This can cause clients to connect to the host X server instead of
# the local Xvnc, leading to authorization failures.
#
# To avoid abstract socket shadowing, find an unused DISPLAY number. This
# ensures X11 clients connect only to the local Xvnc instance and never
# attempt the abstract socket or host X server.
#

for d in $(seq 0 16); do
    if ! netstat -lx | grep -q "/tmp/.X11-unix/X${d}"; then
        echo ":${d}"
        exit 0
    fi
done

echo "ERROR: Could not find available display." >&2
exit 1

